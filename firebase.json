
{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
    // "public": "out", // Removed for serverful deployment
    // "rewrites": [ // Removed for serverful deployment
    //   {
    //     "source": "**",
    //     "destination": "/index.html"
    //   }
    // ]
    // With apphosting.yaml, Firebase CLI should handle rewrites to the App Hosting backend.
    // If specific rewrites to App Hosting are needed, they would look like:
    // "rewrites": [ { "source": "**", "apphosting": { "backendId": "your-backend-id" }} ]
    // but often, this is implicit with apphosting.yaml.
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.log"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ]
}

    
