{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2021",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/types": ["../src/types"],
      "@/types/*": ["../src/types/*"]
    }
  },
  "compileOnSave": true,
  "include": ["src", "../src/types/**/*"]
}
